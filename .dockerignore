# Backend Docker build context exclusions
.git
.venv
__pycache__
*.py[cod]
*.egg-info
.pytest_cache
.ruff_cache

# Frontend (has its own Dockerfile)
frontend/

# Data (volumes, not baked into image)
data/financebench/
data/markdown/
data/uploads/
storage/

# Secrets (injected via env_file, not baked in)
.env
.env.local
.env.*.local

# OS / editor
.DS_Store
.vscode/
.idea/

# Docker files (not needed inside the image)
Dockerfile
docker-compose.yml
.dockerignore
