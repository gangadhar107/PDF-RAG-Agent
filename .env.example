# ── PDF RAG Agent — environment template ──────────────────────────────────────
# Copy to .env and fill in your own values:   cp .env.example .env
# NEVER commit the real .env (it's gitignored).

# ── Database (required) ───────────────────────────────────────────────────────
# Neon (or any Postgres with the pgvector extension). Free tier: https://neon.tech
# Run db_bootstrap.sql once against it to create tables + enable pgvector.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Generation provider (required) ────────────────────────────────────────────
# Which LLM answers questions + writes summaries. Options: gemini | groq
# Default is gemini (works on Google's generous free/billed tier).
LLM_PROVIDER=gemini

# Google Gemini — used for BOTH embeddings (required) and generation (if LLM_PROVIDER=gemini).
# Get a key: https://aistudio.google.com/app/apikey  (enable billing for higher rate limits)
GOOGLE_API_KEY=your-google-api-key

# Groq — only needed if LLM_PROVIDER=groq. Free tier is rate-limited (6K tokens/min).
# Get a key: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-optional

# ── Eval only (optional — not needed to run the app) ──────────────────────────
# Claude Haiku is the LLM-as-judge for the FinanceBench eval harness.
# Get a key: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-optional

# ── Model overrides (optional — sensible defaults in config.py) ────────────────
# GEMINI_GEN_MODEL=gemini-flash-latest
# GEMINI_EMBED_MODEL=gemini-embedding-2
# GROQ_MODEL=llama-3.1-8b-instant
# JUDGE_MODEL=claude-haiku-4-5
# PDF_EXTRACTOR=pymupdf4llm
# MARKDOWN_DIR=data/markdown
